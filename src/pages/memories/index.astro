---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StoryCard from '../../components/StoryCard.astro';

const stories = (
  await getCollection('stories', ({ data }) => data.status === 'published' && data.tags.includes('memories'))
).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
  title="Memories — Humans of Chennai"
  description="Nostalgic, historical stories about old Chennai — vanishing trades, landmarks, and ways of life."
>
  <div class="wrap">
    <p class="section-title">Memories</p>
    <h1 class="page-title">Memories</h1>
    <p class="page-intro">
      Nostalgic, historical stories about old Chennai — vanishing trades, landmarks, and ways of life, told by
      people who lived them.
    </p>
    {
      stories.length > 0 ? (
        <div class="story-grid">
          {stories.map((story) => (
            <StoryCard story={story} />
          ))}
        </div>
      ) : (
        <p class="empty-note">New memories are on the way.</p>
      )
    }
  </div>
</BaseLayout>
