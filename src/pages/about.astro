---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Humans of Chennai">
  <div class="wrap story-body">
    <p>
      Humans of Chennai is a collection of short, first-person stories about
      people across the city &mdash; their neighborhoods, their work, their
      families, and the moments that shaped them.
    </p>
    <p>
      Every story is told in the subject's own words, alongside a portrait,
      and contributed by volunteers who take the time to sit down, listen,
      and write.
    </p>
    <p>
      Want to contribute a story? See the project's
      <a href="https://github.com/tech-itrace/humansofchennai">
        GitHub repository
      </a>
      for how to submit one.
    </p>
  </div>
</BaseLayout>
