---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StoryCard from '../../components/StoryCard.astro';

const stories = (
  await getCollection('stories', ({ data }) => data.status === 'published' && data.tags.includes('moments'))
).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
  title="Moments — Humans of Chennai"
  description="Short, photo-led snapshots from around Chennai — a single striking image and a few lines."
>
  <div class="wrap">
    <p class="section-title">Moments</p>
    <h1 class="page-title">Moments</h1>
    <p class="page-intro">
      Short, photo-led snapshots — a single striking image and a few lines, capturing a moment rather than a full
      story.
    </p>
    {
      stories.length > 0 ? (
        <div class="story-grid">
          {stories.map((story) => (
            <StoryCard story={story} />
          ))}
        </div>
      ) : (
        <p class="empty-note">New moments are on the way.</p>
      )
    }
  </div>
</BaseLayout>
